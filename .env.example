# Server
PORT=3001
ADMIN_PASSWORD=caption-studio-admin

# AI — groq for testing, anthropic for production
AI_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ANTHROPIC_API_KEY=sk-ant-your-key-here
# AI_PROVIDER=anthropic
CLAUDE_MODEL=claude-sonnet-4-20250514

# Postgres (local docker-compose or Railway Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/caption_studio

# Comma-separated origins, or * 
CORS_ORIGIN=*

# Client — leave empty when API serves the frontend (Railway single service)
VITE_API_URL=
